# ContextForge Environment Configuration
# Copy this file to .env and fill in your API keys
# LiteLLM is used as the universal provider layer — set keys for whichever
# providers you want to use. At least one provider key is required.

# ─── OpenAI ────────────────────────────────────────────────────────────
# Docs: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Google Gemini ─────────────────────────────────────────────────────
# Docs: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Groq (ultra-fast inference) ───────────────────────────────────────
# Docs: https://console.groq.com/keys
GROQ_API_KEY=

# ─── xAI (Grok) ────────────────────────────────────────────────────────
# Docs: https://console.x.ai/
XAI_API_KEY=

# ─── Mistral AI ────────────────────────────────────────────────────────
# Docs: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# ─── Cohere ────────────────────────────────────────────────────────────
# Docs: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ─── Anthropic (Claude) ────────────────────────────────────────────────
# Docs: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Ollama (local models) ─────────────────────────────────────────────
# Set to your Ollama server URL. Default: http://localhost:11434
# Use models like: ollama/llama3, ollama/mistral, etc.
OLLAMA_BASE_URL=http://localhost:11434

# ─── Default Model Tiers ───────────────────────────────────────────────
# Model used for simple/cheap routing tier. Supports provider-prefixed names.
# Examples: gpt-3.5-turbo, groq/llama3-8b-8192, gemini/gemini-1.5-flash
SIMPLE_MODEL=gpt-3.5-turbo

# Model used for complex/capable routing tier.
# Examples: gpt-4o, anthropic/claude-3-5-sonnet-20241022, gemini/gemini-1.5-pro
COMPLEX_MODEL=gpt-4o

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# LiteLLM built-in response cache (exact-match, complements the FAISS semantic cache)
# Set ENABLE_CACHE=true and ensure Redis is running to activate
ENABLE_CACHE=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=          # leave blank if no auth

# ─── Semantic Cache ────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.92
CACHE_TTL_SECONDS=86400

# ─── Context Compression ───────────────────────────────────────────────
# Compression kicks in when BOTH conditions are met:
#   1. The total token count of the conversation exceeds this threshold.
#   2. The conversation has more than COMPRESSION_MIN_TURNS non-system messages.
# Increase this value to compress less aggressively (e.g. 4000 for GPT-4).
COMPRESS_THRESHOLD=2000

# Minimum number of non-system messages before compression is considered.
# Prevents summarising very short conversations where context loss is harmful.
COMPRESS_MIN_TURNS=6

# How many of the most-recent non-system turns to keep verbatim (not summarised).
# The compressor always keeps the system message + these recent turns untouched.
COMPRESS_KEEP_RECENT=4

# Fast, cheap model used to generate the conversation summary.
# Groq's llama3-8b is a good free alternative: groq/llama3-8b-8192
COMPRESS_SUMMARY_MODEL=gpt-3.5-turbo

# ─── Model Routing ─────────────────────────────────────────────────────
PREFERRED_PROVIDER=openai

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Storage Paths ─────────────────────────────────────────────────────
SQLITE_DB_PATH=./data/telemetry.db
FAISS_INDEX_PATH=./data/faiss.index

# ─── OpenAI Base URL (for custom endpoints / testing / local proxies) ──
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Adaptive Threshold ────────────────────────────────────────────────
ADAPTIVE_THRESHOLD_ENABLED=true
ADAPTIVE_THRESHOLD_WINDOW=100
ADAPTIVE_THRESHOLD_MIN=0.70
ADAPTIVE_THRESHOLD_MAX=0.98

# ─── Test Mode (forces cheapest model for all requests) ────────────────
TEST_MODE=false

# ─── OpenTelemetry (Phase 3) ───────────────────────────────────────────
# Set ENABLE_OTEL=true and point to your OTLP collector (e.g. Jaeger, Grafana).
# The OTel SDK is always installed; tracing is a no-op when this is false.
ENABLE_OTEL=false
OTEL_ENDPOINT=http://localhost:4317